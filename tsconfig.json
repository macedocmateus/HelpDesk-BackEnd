{
  "$schema": "https://www.schemastore.org/tsconfig",
  "_version": "24.0.0",

  "compilerOptions": {
    "target": "es2024",
    "lib": [
      "es2024",
      "ESNext.Array",
      "ESNext.Collection",
      "ESNext.Error",
      "ESNext.Iterator",
      "ESNext.Promise"
    ],

    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,

    "rootDir": "./src",
    "outDir": "./dist",

    "types": ["node", "jest"],
    "paths": {
      "#/*": ["./src/*"]
    },

    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "isolatedModules": true
  },
  "include": ["src/**/*"]
}
