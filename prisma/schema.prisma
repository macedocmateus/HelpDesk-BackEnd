generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  technician
  customer
}

enum TicketStatus {
  open
  in_progress
  closed
}

model User {
  id        String   @id @default(uuid(7))
  name      String
  email     String   @unique
  password  String
  role      Role     @default(customer)
  avatar    String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  technicianProfile   TechnicianProfile?
  ticketsAsClient     Ticket[]           @relation("ClientTickets")
  ticketsAsTechnician Ticket[]           @relation("TechnicianTickets")

  @@map("user")
}

model TechnicianProfile {
  id             String   @id @default(uuid(7))
  userId         String   @unique @map("user_id")
  availableHours String[] @map("available_hours")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("technician_profile")
}

model Service {
  id        String   @id @default(uuid(7))
  name      String
  price     Decimal  @db.Decimal(10, 2)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ticketServices TicketService[]

  @@map("service")
}

model Ticket {
  id           String       @id @default(uuid(7))
  status       TicketStatus @default(open)
  clientId     String       @map("client_id")
  technicianId String       @map("technician_id")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  client         User            @relation("ClientTickets", fields: [clientId], references: [id], onDelete: Cascade)
  technician     User            @relation("TechnicianTickets", fields: [technicianId], references: [id])
  ticketServices TicketService[]

  @@map("ticket")
}

model TicketService {
  id        String   @id @default(uuid(7))
  ticketId  String   @map("ticket_id")
  serviceId String   @map("service_id")
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")

  ticket  Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@map("ticket_service")
}
